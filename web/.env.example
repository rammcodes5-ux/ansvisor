# =============================================================================
# AEO Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# AI API Keys (users can provide their own)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Agent (in-product BYOK)
# -----------------------------------------------------------------------------
# Cloud customers paste their own Anthropic key in Settings → Agent. We
# encrypt it at rest with AES-256-GCM; this is the master key. Must be a
# 32-byte (256-bit) value, base64-encoded.
#   Generate one: `openssl rand -base64 32`
# Self-host instances can skip this — they use ANTHROPIC_API_KEY directly.
ANSVISOR_ENCRYPTION_KEY=base64-32-bytes-here
PERPLEXITY_API_KEY=pplx-...
GROK_API_KEY=xai-...

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Product analytics (optional — OFF by default for self-hosted)
# -----------------------------------------------------------------------------
# When unset, PostHog is never loaded and no events are sent anywhere.
# Set NEXT_PUBLIC_POSTHOG_KEY to enable funnel / retention analytics. You can
# point it at PostHog Cloud, your own self-hosted PostHog, or any compatible
# endpoint via NEXT_PUBLIC_POSTHOG_HOST. The official cloud deployment uses
# its own PostHog project; self-host users get zero telemetry by default.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Cloud / Self-hosted mode
# Set to "true" only for the official cloud deployment.
# Self-hosted instances should leave this unset or "false" — all features
# will be unlocked automatically.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_IS_CLOUD=false

# -----------------------------------------------------------------------------
# AEO Server (backend API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:80

# -----------------------------------------------------------------------------
# Cron / Internal-endpoint secret (cloud only — not needed for self-hosted)
# -----------------------------------------------------------------------------
# Shared secret that authenticates calls from the web layer to the server's
# internal endpoints. Used by:
#   - Vercel Cron  →  /api/cron/daily-tracking
#   - Stripe success route  →  post-checkout tracking trigger
#   - MCP layer  →  content-brief generation (throws if unset)
# Web sends:  Authorization: Bearer ${CRON_SECRET}
# Server checks its own CRON_SECRET copy — both values MUST match.
# Generate: openssl rand -hex 32
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Stripe (cloud only — not needed for self-hosted)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
# STRIPE_GROWTH_MONTHLY_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Supabase Service Role Key (cloud only — for Stripe webhooks)
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
